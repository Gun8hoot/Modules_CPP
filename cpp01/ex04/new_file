NAME = sed_is_for_losers

CPPC = c++
CFLAGS = -Wall -Wextra -Werror -std=c++98 -g3 -I.

SRCS =		sources/main.<ALL>

OBJS = $(SRCS:%.<ALL>=%.o)

all : $(NAME)


%.o : %.<ALL>
	$(CPPC) $(CFLAGS) -c $< -o $@

$(NAME): $(OBJS)
	$(CPPC) $(OBJS) -o $@

clean :
	rm -f $(OBJS)

fclean : clean
	rm -f $(NAME)

re : fclean $(NAME)

.PHONY: re all clean fclean $(NAME)
